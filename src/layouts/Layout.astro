---
// src/layouts/Layout.astro
const { title = 'Crônicas', description = 'Meu blog de alta performance' } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Source+Serif+4:wght@400;600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-stone-50 text-stone-800 antialiased">
    <header class="border-b border-stone-200 bg-white/80 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-3xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="font-serif text-xl font-bold text-stone-900 italic">✦ Crônicas</a>
        <div class="flex gap-6 text-sm font-medium">
          <a href="/" class="hover:text-amber-600">Posts</a>
          <a href="/sobre" class="hover:text-amber-600">Sobre</a>
        </div>
      </nav>
    </header>
    <main class="max-w-3xl mx-auto px-6 py-12 min-h-screen">
      <slot />
    </main>
    <footer class="border-t border-stone-200 py-8 text-center text-sm text-stone-400">
      <p>© {new Date().getFullYear()} Crônicas — Feito com Astro</p>
    </footer>
  </body>
</html>
<style is:global>
  h1, h2, h3 { font-family: 'Playfair Display', serif; }
  body { font-family: 'Source Serif 4', serif; }
</style>
