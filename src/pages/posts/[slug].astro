---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/posts/*.{md,mdx}');
  return posts.map(post => ({
    params: { 
      slug: post.file.split('/').pop().split('.')[0] 
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
---

<Layout title={post.frontmatter.title}>
  <article class="prose prose-stone lg:prose-xl mx-auto italic">
    <header class="mb-8 border-b border-stone-200 pb-8">
      <time class="text-amber-600 font-semibold uppercase tracking-widest text-sm">
        {post.frontmatter.date}
      </time>
      <h1 class="text-5xl font-bold text-stone-900 mt-2 font-serif">
        {post.frontmatter.title}
      </h1>
      <p class="text-stone-500 text-xl mt-4 leading-relaxed">
        {post.frontmatter.summary}
      </p>
    </header>
    
    <div class="text-stone-800 leading-loose space-y-6 font-serif text-lg">
      <Content />
    </div>
    
    <div class="mt-16 pt-8 border-t border-stone-200">
      <a href="/" class="text-stone-900 font-bold hover:text-amber-600 transition-colors">
        ← Voltar para a página inicial
      </a>
    </div>
  </article>
</Layout>
